APP_VERSION=1.2.0
DEDOS_IMAGE=dedos-server:latest
TUNNEL_TOKEN_FILE=/etc/dedos/tunnel-token.txt
DEDOS_BACKUP_DIR=/var/backups/dedos
DEDOS_BACKUP_RETENTION_DAYS=30
DEDOS_BACKUP_KEEP=30
PUBLIC_HEALTH_URL=https://dedos.adelsamir.com/health
# Optional: receives a JSON POST when health monitoring fails.
ALERT_WEBHOOK_URL=
