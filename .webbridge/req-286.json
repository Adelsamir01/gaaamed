{"action":"evaluate","args":{"code":"(async()=>{const secs=[...document.querySelectorAll('console-section')];const sec=secs.find(s=>(s.textContent||'').includes('Personal info'));const row=[...sec.querySelectorAll('.particle-table-row')].find(r=>(r.textContent||'').includes('Name'));const btn=[...row.querySelectorAll('button')].find(b=>(b.textContent||'').trim().startsWith('Start'));row.scrollIntoView({block:'center'});await new Promise(r=>setTimeout(r,600));btn.id='start-btn';return 'tagged Name';})()"},"session":"dedos-play-publish"}